---
---
<section id="contatti" class="py-24 md:py-36 px-6" style="background: linear-gradient(160deg, #0a1a3a 0%, #1B3A6B 100%);">
  <div class="max-w-5xl mx-auto">

    <div class="text-center mb-16">
      <p class="text-turquoise text-xs tracking-[0.35em] uppercase mb-4 font-light">Dove Siamo</p>
      <h2 class="text-white" style="font-family: 'Playfair Display', serif; font-style: italic; font-size: clamp(2rem, 4vw, 3rem);">
        Contatti
      </h2>
      <div class="w-12 h-px bg-turquoise mx-auto mt-6"></div>
    </div>

    <div class="grid md:grid-cols-3 gap-6">

      <!-- Location -->
      <div class="bg-white/5 border border-white/10 rounded-xl p-8 text-center hover:bg-white/10 hover:border-turquoise/30 transition-all duration-300">
        <div class="w-12 h-12 rounded-full border border-turquoise/40 flex items-center justify-center mx-auto mb-5">
          <svg class="w-5 h-5 text-turquoise" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
        </div>
        <h3 class="text-white text-sm tracking-widest uppercase mb-3 font-light" style="letter-spacing: 0.15em;">Indirizzo</h3>
        <p class="text-white/55 font-light text-sm leading-relaxed">
          Via Indipendenza 5<br />
          Gaeta (LT)
        </p>
      </div>

      <!-- Email -->
      <div class="bg-white/5 border border-white/10 rounded-xl p-8 text-center hover:bg-white/10 hover:border-turquoise/30 transition-all duration-300">
        <div class="w-12 h-12 rounded-full border border-turquoise/40 flex items-center justify-center mx-auto mb-5">
          <svg class="w-5 h-5 text-turquoise" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
        </div>
        <h3 class="text-white text-sm tracking-widest uppercase mb-3 font-light" style="letter-spacing: 0.15em;">Email</h3>
        <a
          href="mailto:domenico.solino@gmail.com"
          class="text-white/55 hover:text-turquoise transition-colors font-light text-sm break-all"
        >
          domenico.solino@gmail.com
        </a>
      </div>

      <!-- Owner -->
      <div class="bg-white/5 border border-white/10 rounded-xl p-8 text-center hover:bg-white/10 hover:border-turquoise/30 transition-all duration-300">
        <div class="w-12 h-12 rounded-full border border-turquoise/40 flex items-center justify-center mx-auto mb-5">
          <svg class="w-5 h-5 text-turquoise" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
          </svg>
        </div>
        <h3 class="text-white text-sm tracking-widest uppercase mb-3 font-light" style="letter-spacing: 0.15em;">Titolare</h3>
        <p class="text-white/55 font-light text-sm">
          Domenico Solino
        </p>
      </div>

    </div>
  </div>
</section>
