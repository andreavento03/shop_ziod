---
---
<section id="home" class="relative min-h-screen flex items-center justify-center overflow-hidden">
  <!-- Background photo -->
  <img
    src="/clothes/abiti/item-001.jpeg"
    alt=""
    aria-hidden="true"
    class="absolute inset-0 w-full h-full object-cover object-center"
  />

  <!-- Warm dark overlay for legibility -->
  <div class="absolute inset-0" style="background: linear-gradient(160deg, rgba(10,5,2,0.72) 0%, rgba(20,10,4,0.55) 55%, rgba(10,5,2,0.65) 100%);"></div>

  <!-- Content -->
  <div class="relative z-10 text-center px-6 max-w-3xl mx-auto">
    <p class="text-xs tracking-[0.4em] uppercase mb-6 font-light" style="color: #D4B896;">Gaeta &nbsp;·&nbsp; Boutique Artigianale</p>

    <h1 class="text-white leading-none mb-6" style="font-family: 'Playfair Display', serif; font-style: italic; font-weight: 400; font-size: clamp(3.5rem, 10vw, 7rem); text-shadow: 0 2px 24px rgba(0,0,0,0.4);">
      Emporio Filitalia
    </h1>

    <div class="flex items-center justify-center gap-4 mb-6">
      <div class="h-px w-16" style="background: rgba(212,184,150,0.5);"></div>
      <span class="text-base" style="color: rgba(212,184,150,0.6);">⚓</span>
      <div class="h-px w-16" style="background: rgba(212,184,150,0.5);"></div>
    </div>

    <p class="text-white/70 text-sm md:text-base tracking-[0.25em] uppercase font-light mb-12">
      Eleganza sul Mare
    </p>

    <a
      href="#collezione"
      class="inline-block border border-white/30 text-white/90 text-xs tracking-[0.25em] uppercase px-10 py-4 hover:bg-white hover:text-navy transition-all duration-400 font-light"
    >
      Scopri la Collezione
    </a>
  </div>

  <!-- Animated scroll indicator -->
  <div class="absolute bottom-20 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 animate-bounce">
    <div class="w-px h-10 bg-white/20"></div>
    <svg class="w-4 h-4 text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7" />
    </svg>
  </div>

  <!-- Wave transition to About -->
  <div class="absolute bottom-0 left-0 right-0 overflow-hidden leading-none">
    <svg viewBox="0 0 1440 80" preserveAspectRatio="none" class="w-full" style="height: 80px; display: block;" fill="#F5F0E8">
      <path d="M0,40 C240,80 480,0 720,40 C960,80 1200,0 1440,40 L1440,80 L0,80 Z" />
    </svg>
  </div>
</section>
